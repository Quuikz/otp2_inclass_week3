<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.otp.FuelCalculatorController">
    <padding>
        <Insets top="16.0" right="16.0" bottom="16.0" left="16.0"/>
    </padding>

    <HBox spacing="8.0">
        <Label text="Language:"/>
        <Button fx:id="btnEN" text="EN" onAction="#onEnglishSelected"/>
        <Button fx:id="btnFR" text="FR" onAction="#onFrenchSelected"/>
        <Button fx:id="btnJP" text="JP" onAction="#onJapaneseSelected"/>
        <Button fx:id="btnIR" text="IR" onAction="#onPersianSelected"/>
    </HBox>

    <GridPane hgap="10.0" vgap="10.0">
        <columnConstraints>
            <ColumnConstraints minWidth="140.0"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label fx:id="lblDistance" text="Distance (km)" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="txtDistance" promptText="Example: 180" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label fx:id="lblConsumption" text="Fuel Consumption (L/100 km)" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="txtConsumption" promptText="Example: 6.5" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label fx:id="lblPrice" text="Fuel Price (per liter)" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="txtPrice" promptText="Example: 2.05" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
    </GridPane>

    <Button fx:id="btnCalculate" text="Calculate Trip Cost" onAction="#onCalculate" maxWidth="Infinity" VBox.vgrow="NEVER"/>

    <Label fx:id="lblResult" text="Result will appear here." wrapText="true"/>
</VBox>

